# ⚠️ ATENÇÃO: Variáveis com prefixo VITE_ ficam VISÍVEIS no navegador!
# Nunca coloque secrets sensíveis aqui. Restrinja as chaves de API
# no painel do provedor (ex: Google Cloud Console → restringir por domínio).

# Supabase (anon key é público por design — ok no frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service Role Key — NUNCA exponha no frontend!
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini (EXPOSTA no frontend — restrinja por domínio no Google Cloud)
VITE_GEMINI_API_KEY=

# UAZAPI (EXPOSTA no frontend)
VITE_UAZAPI_BASE_URL=
VITE_UAZAPI_INSTANCE_TOKEN=
VITE_SUPERADMIN_WHATSAPP=
